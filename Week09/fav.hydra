src(o0)
  .brightness(()=>Math.random()*0.000002)
  .modulate(noise(10,0.02,)) .kaleid(() => k())
  .diff(osc(10,0.06))
  .color(1.02,0.8,0.1)
  .modulateScale(osc(2,0.1,0.0003).kaleid(1).scale(1),10,0.2)
  .out(o0)

src(o1)
	.modulate(noise(1,0.0003,2))
.kaleid(5)
	.color(1.02,0.01,0.39)
	.rotate(12, 0.5)
.thresh(0.9)
	.modulate(o0, () => mouse.x * 0.003)
	.scale(1)
.thresh(0.5)
  .out(o1)


src(o0).blend(src(o1), 0.2)
