voronoi(8,3,0.25)
  .modulateScale(osc(8).rotate(Math.sin(time)),.1)
  .thresh(.6)
  .modulateRotate(osc(2),0.86)
  .thresh(0.5)
  .diff(src(o0).scale(5))
  .modulateScale(osc(4).modulateRotate(o0,.95))
  .diff(src(o0).rotate([-12,20,.01,-.002,0]).scrollY(0,[-1/1999800,0].fast(0.7)))
  .brightness([-.01,-.30].smooth(1).fast(.5))
  .color(1,0.6,0.2)
  .out()
