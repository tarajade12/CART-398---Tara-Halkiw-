
voronoi(350,500,0.25,0.75)
  	.modulateScale(osc(1).rotate(Math.sin(time)),.5)
	.modulateRotate(osc(6),.8)
	.thresh(.2)
  .diff(src(o0).scale(4))
	.modulateScale(osc(6).modulateRotate(o0,.7))
	.diff(src(o0).rotate([-2,.0008,-.002]).scrollY(0,[0.5/19800,0].fast(0.9)))
	.brightness([-.09,-.17].smooth().fast(.5))
	.color(2,0.9,0,1,6)
	.out()
